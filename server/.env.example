# ── Neon PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/floagency?sslmode=require

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_min_64_chars_long_change_this_in_production
JWT_REFRESH_SECRET=your_refresh_secret_also_min_64_chars_change_this_too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
# In production: CLIENT_URL=https://youragency.github.io

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
