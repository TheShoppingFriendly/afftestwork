# ── API URL ───────────────────────────────────────────────────
# Development (uses Vite proxy — just use /api)
VITE_API_URL=

# Production — your Render server URL
# VITE_API_URL=https://affwork.onrender.com

# ── WebSocket URL ──────────────────────────────────────────────
# Development
VITE_WS_URL=ws://localhost:4000

# Production
# VITE_WS_URL=wss://affwork.onrender.com
